includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app/

    level: 5

    ignoreErrors:
        # Spatie Activity Log — dynamic properties on Activity model
        - '#Access to an undefined property Spatie\\Activitylog\\Models\\Activity::#'

        # Spatie MediaLibrary — driver method resolution
        - '#Call to an undefined method Spatie\\Image\\Drivers\\ImageDriver::performOnCollections#'

        # Laravel API Resources — $this->property delegates to underlying model
        -
            message: '#Access to an undefined property App\\Http\\Resources\\#'
            path: app/Http/Resources/

    excludePaths:
        - app/Providers/Filament
